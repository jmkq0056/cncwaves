<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/ingredient_button"
    android:tag="layout/item_ingredient_0"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="15dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/item_extra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="90dp"
            android:layout_height="90dp">
            <ImageView
                android:tag="binding_1"
                android:layout_width="90dp"
                android:layout_height="90dp"/>
            <ImageView
                android:tag="binding_2"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/ingredient_cross"/>
        </RelativeLayout>
        <TextView
            android:textSize="22sp"
            android:tag="binding_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="7dp"
            android:fontFamily="@font/uni_sans"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-15dp">
        <Space
            android:layout_width="214dp"
            android:layout_height="match_parent"/>
        <ImageButton
            android:id="@+id/remove"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/minus_extra"
            android:scaleType="fitXY"/>
    </LinearLayout>
</LinearLayout>
