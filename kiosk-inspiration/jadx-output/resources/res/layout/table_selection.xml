<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <Space
            android:layout_width="match_parent"
            android:layout_height="50dp"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/logo"
            android:layout_width="300dp"
            android:layout_height="300dp"/>
        <Space
            android:layout_width="match_parent"
            android:layout_height="75dp"/>
        <TextView
            android:textSize="50sp"
            android:textColor="@color/black"
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_your_table"
            android:fontFamily="@font/uni_sans"
            android:textAlignment="center"/>
        <Space
            android:layout_width="match_parent"
            android:layout_height="75dp"/>
    </LinearLayout>
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/tables"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="100dp"
        android:layout_marginEnd="100dp"
        app:layout_constraintTop_toBottomOf="@+id/title"/>
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@+id/tables_indicators_wrap"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/tables">
        <RelativeLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/table_previous"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginEnd="10dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/navigate_left"/>
        </RelativeLayout>
        <me.relex.circleindicator.CircleIndicator3
            android:id="@+id/tables_indicators"
            android:layout_width="wrap_content"
            android:layout_height="70dp"
            app:ci_drawable="@drawable/page_indicator_new_active"
            app:ci_drawable_unselected="@drawable/page_indicator_new"
            app:ci_height="20dp"
            app:ci_margin="10dp"
            app:ci_width="20dp"/>
        <RelativeLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/table_next"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginStart="10dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/navigate_right"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/bottom_nav"
        android:padding="80dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="30sp"
            android:textColor="@color/white"
            android:id="@+id/back_button"
            android:background="@drawable/danger_button"
            android:layout_width="230dp"
            android:layout_height="wrap_content"
            android:text="@string/table_back"
            android:fontFamily="@font/uni_sans"
            android:paddingVertical="30dp"/>
        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="30sp"
            android:textColor="@color/white"
            android:id="@+id/confirm_button"
            android:background="@drawable/success_button"
            android:layout_width="230dp"
            android:layout_height="wrap_content"
            android:text="@string/table_confirm"
            android:fontFamily="@font/uni_sans"
            android:paddingVertical="30dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
