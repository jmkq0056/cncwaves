<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/item_configuration_0"
    android:padding="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:tag="binding_1"
        android:layout_width="match_parent"
        android:layout_height="1470dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <Space
                android:layout_width="250dp"
                android:layout_height="wrap_content"/>
            <ImageView
                android:layout_gravity="center"
                android:tag="binding_2"
                android:layout_width="0dp"
                android:layout_height="350dp"
                android:layout_weight="1"/>
            <RelativeLayout
                android:layout_gravity="bottom|right"
                android:layout_width="250dp"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatButton
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/yourway"
                    android:background="@drawable/danger_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Have it your way"
                    android:fontFamily="@font/uni_sans"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="17dp"/>
                <ImageView
                    android:id="@+id/yourway_hand"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/hand"
                    android:layout_marginStart="30dp"/>
            </RelativeLayout>
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp"/>
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="40sp"
                android:textColor="@color/black"
                android:tag="binding_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/uni_sans"/>
            <Space
                android:layout_width="50dp"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="40sp"
                android:textColor="@color/black"
                android:tag="binding_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/uni_sans"/>
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp"/>
        <TextView
            android:textSize="25sp"
            android:textColor="@color/black"
            android:layout_gravity="center"
            android:tag="binding_5"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:fontFamily="@font/uni_sans"
            android:textAlignment="center"/>
        <androidx.core.widget.NestedScrollView
            android:id="@+id/extras_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView
                    android:scrollbarSize="15dp"
                    android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
                    android:scrollbarTrackVertical="@drawable/scrollbar_track"
                    android:id="@+id/extras"
                    android:scrollbars="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/remove_items"
                    android:visibility="invisible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="10dp"/>
                    <TextView
                        android:textSize="35sp"
                        android:textColor="@color/black"
                        android:id="@+id/remove_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/remove_ingredients_title"
                        android:fontFamily="@font/uni_sans"
                        android:layout_marginStart="30dp"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:scrollbarSize="15dp"
                        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
                        android:scrollbarTrackVertical="@drawable/scrollbar_track"
                        android:id="@+id/ingredients"
                        android:scrollbars="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:tag="binding_6"
        android:layout_width="match_parent"
        android:layout_height="1040dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <Space
                android:layout_width="250dp"
                android:layout_height="wrap_content"/>
            <ImageView
                android:layout_gravity="center"
                android:tag="binding_7"
                android:layout_width="0dp"
                android:layout_height="350dp"
                android:layout_weight="1"/>
            <RelativeLayout
                android:layout_gravity="bottom|right"
                android:layout_width="250dp"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatButton
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/yourway_handicap"
                    android:background="@drawable/danger_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Have it your way"
                    android:fontFamily="@font/uni_sans"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="17dp"/>
                <ImageView
                    android:id="@+id/yourway_handicap_hand"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/hand"
                    android:layout_marginStart="30dp"/>
            </RelativeLayout>
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="50dp"/>
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="40sp"
                android:textColor="@color/black"
                android:tag="binding_8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/uni_sans"/>
            <Space
                android:layout_width="50dp"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="40sp"
                android:textColor="@color/black"
                android:tag="binding_9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/uni_sans"/>
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp"/>
        <TextView
            android:textSize="25sp"
            android:textColor="@color/black"
            android:layout_gravity="center"
            android:tag="binding_10"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:fontFamily="@font/uni_sans"
            android:textAlignment="center"/>
        <androidx.core.widget.NestedScrollView
            android:id="@+id/extras_handicap_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView
                    android:scrollbarSize="15dp"
                    android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
                    android:scrollbarTrackVertical="@drawable/scrollbar_track"
                    android:id="@+id/extras_handicap"
                    android:scrollbars="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/remove_items_ingredients"
                    android:visibility="invisible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="10dp"/>
                    <TextView
                        android:textSize="35sp"
                        android:textColor="@color/black"
                        android:id="@+id/handicap_remove_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/remove_ingredients_title"
                        android:fontFamily="@font/uni_sans"
                        android:layout_marginStart="30dp"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:scrollbarSize="15dp"
                        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
                        android:scrollbarTrackVertical="@drawable/scrollbar_track"
                        android:id="@+id/ingredients_handicap"
                        android:scrollbars="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="50dp"
        android:paddingVertical="20dp">
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="30sp"
            android:textColor="@color/white"
            android:id="@+id/cancel_button"
            android:tag="binding_11"
            android:background="@drawable/danger_button"
            android:layout_width="230dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/uni_sans"
            android:paddingVertical="30dp"/>
        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="30sp"
            android:textColor="@color/white"
            android:id="@+id/next_button"
            android:tag="binding_12"
            android:background="@drawable/success_button"
            android:layout_width="230dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/uni_sans"
            android:paddingVertical="30dp"/>
    </LinearLayout>
</LinearLayout>
