<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="bottom"
    android:tag="layout/option_layout_handicap_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_gravity="center"
            android:tag="binding_1"
            android:layout_width="500dp"
            android:layout_height="500dp"/>
        <Space
            android:layout_width="match_parent"
            android:layout_height="75dp"/>
        <TextView
            android:textSize="50sp"
            android:textColor="@color/black"
            android:tag="binding_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/uni_sans"
            android:textAlignment="center"/>
        <Space
            android:layout_width="match_parent"
            android:layout_height="175dp"/>
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:tag="binding_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center"
                    android:id="@+id/takeAwayButton"
                    android:background="@drawable/option_button"
                    android:padding="67dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center"
                        android:layout_width="112dp"
                        android:layout_height="112dp"
                        android:src="@drawable/takeaway"/>
                </LinearLayout>
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="30dp"/>
                <TextView
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:tag="binding_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/uni_sans"/>
            </LinearLayout>
            <Space
                android:tag="binding_5"
                android:layout_width="37dp"
                android:layout_height="wrap_content"/>
            <Space
                android:tag="binding_6"
                android:layout_width="37dp"
                android:layout_height="wrap_content"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:tag="binding_7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center"
                    android:id="@+id/dineInButton"
                    android:background="@drawable/option_button"
                    android:padding="67dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center"
                        android:layout_width="112dp"
                        android:layout_height="112dp"
                        android:src="@drawable/dinein"/>
                </LinearLayout>
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="30dp"/>
                <TextView
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:tag="binding_8"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/uni_sans"/>
            </LinearLayout>
            <Space
                android:tag="binding_9"
                android:layout_width="37dp"
                android:layout_height="wrap_content"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:tag="binding_10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center"
                    android:id="@+id/pickUpButton"
                    android:background="@drawable/option_button"
                    android:padding="67dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center"
                        android:layout_width="112dp"
                        android:layout_height="112dp"
                        android:src="@drawable/pickup"/>
                </LinearLayout>
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="30dp"/>
                <TextView
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:tag="binding_11"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/uni_sans"/>
            </LinearLayout>
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="100dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="100dp"
            android:layout_marginEnd="100dp">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="32sp"
                    android:textColor="@color/black"
                    android:tag="binding_12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/uni_sans"/>
                <Space
                    android:layout_width="wrap_content"
                    android:layout_height="37dp"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/languages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <LinearLayout
                android:gravity="center"
                android:id="@+id/handicapButton"
                android:background="@drawable/option_button"
                android:padding="40dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/handicap"/>
            </LinearLayout>
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="80dp"/>
    </LinearLayout>
</RelativeLayout>
