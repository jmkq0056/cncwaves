<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/voucher_0"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <TextView
            android:textSize="70sp"
            android:textColor="@color/black"
            android:id="@+id/voucher_code_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enter_your_voucher_code_here"
            android:fontFamily="@font/uni_sans"
            android:textAlignment="center"
            android:paddingHorizontal="150dp"/>
        <Space
            android:layout_width="match_parent"
            android:layout_height="100dp"/>
        <TextView
            android:textSize="60sp"
            android:id="@+id/voucher_display"
            android:tag="binding_1"
            android:background="@drawable/voucher_display"
            android:padding="20dp"
            android:layout_width="663dp"
            android:layout_height="wrap_content"/>
        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:tag="binding_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="40dp"
                android:textColor="#438d02"
                android:id="@+id/coupon_applied_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/coupon_applied_successfully"
                android:fontFamily="@font/uni_sans"/>
            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
            <androidx.appcompat.widget.AppCompatButton
                android:textSize="30sp"
                android:textColor="@color/white"
                android:id="@+id/remove_coupon"
                android:background="@drawable/danger_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remove Coupon"
                android:fontFamily="@font/uni_sans"
                android:paddingHorizontal="50dp"
                android:paddingVertical="20dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/voucher_keyboard"
            android:tag="binding_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_1"
                    android:layout_marginLeft="0dp"
                    android:text="1"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_2"
                    android:text="2"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_3"
                    android:text="3"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_4"
                    android:text="4"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_5"
                    android:text="5"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_6"
                    android:text="6"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_7"
                    android:text="7"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_8"
                    android:text="8"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_9"
                    android:text="9"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_0"
                    android:text="0"
                    style="@style/voucherKeyStyle"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_q"
                    android:tag="binding_4"
                    android:layout_marginLeft="0dp"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_w"
                    android:tag="binding_5"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_e"
                    android:tag="binding_6"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_r"
                    android:tag="binding_7"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_t"
                    android:tag="binding_8"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_y"
                    android:tag="binding_9"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_u"
                    android:tag="binding_10"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_i"
                    android:tag="binding_11"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_o"
                    android:tag="binding_12"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_p"
                    android:tag="binding_13"
                    style="@style/voucherKeyStyle"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_a"
                    android:tag="binding_14"
                    android:layout_marginLeft="0dp"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_s"
                    android:tag="binding_15"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_d"
                    android:tag="binding_16"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_f"
                    android:tag="binding_17"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_g"
                    android:tag="binding_18"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_h"
                    android:tag="binding_19"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_j"
                    android:tag="binding_20"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_k"
                    android:tag="binding_21"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_l"
                    android:tag="binding_22"
                    style="@style/voucherKeyStyle"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/capslock_button"
                    android:layout_marginLeft="0dp"
                    android:drawableStart="@drawable/capslock"
                    android:paddingStart="15dp"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_z"
                    android:tag="binding_23"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_x"
                    android:tag="binding_24"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_c"
                    android:tag="binding_25"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_v"
                    android:tag="binding_26"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_b"
                    android:tag="binding_27"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_n"
                    android:tag="binding_28"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/voucher_key_m"
                    android:tag="binding_29"
                    style="@style/voucherKeyStyle"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/backspace_button"
                    android:drawableStart="@drawable/backspace"
                    android:paddingStart="15dp"
                    style="@style/voucherKeyStyle"/>
            </LinearLayout>
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="150dp"/>
        <RelativeLayout
            android:layout_gravity="end"
            android:id="@+id/voucher_warning"
            android:background="@drawable/danger_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:translationX="400dp"
            android:paddingHorizontal="30dp"
            android:paddingVertical="15dp">
            <TextView
                android:textSize="26sp"
                android:textColor="#ffffff"
                android:id="@+id/warning_select"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/invalid_voucher_code"
                android:fontFamily="@font/uni_sans"/>
        </RelativeLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:tag="binding_30"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="50dp"
            android:paddingVertical="50dp">
            <androidx.appcompat.widget.AppCompatButton
                android:textSize="30sp"
                android:textColor="@color/white"
                android:id="@+id/cancel_button"
                android:background="@drawable/danger_button"
                android:layout_width="230dp"
                android:layout_height="wrap_content"
                android:text="Close"
                android:fontFamily="@font/uni_sans"
                android:paddingVertical="20dp"/>
            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
            <androidx.appcompat.widget.AppCompatButton
                android:textSize="30sp"
                android:textColor="@color/white"
                android:id="@+id/apply_button"
                android:background="@drawable/success_button"
                android:layout_width="230dp"
                android:layout_height="wrap_content"
                android:text="Apply"
                android:fontFamily="@font/uni_sans"
                android:paddingVertical="20dp"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:tag="binding_31"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="50dp"
            android:paddingVertical="50dp">
            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
            <androidx.appcompat.widget.AppCompatButton
                android:textSize="30sp"
                android:textColor="@color/white"
                android:id="@+id/continue_button"
                android:background="@drawable/success_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Continue Shopping"
                android:fontFamily="@font/uni_sans"
                android:paddingHorizontal="50dp"
                android:paddingVertical="20dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
