<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/item_extra_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="15dp">
    <LinearLayout
        android:orientation="vertical"
        android:tag="binding_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:translationZ="1dp">
            <TextView
                android:textSize="20sp"
                android:textStyle="italic"
                android:textColor="@color/white"
                android:tag="binding_2"
                android:background="@drawable/item_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:fontFamily="@font/uni_sans"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"/>
            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/white"
                android:tag="binding_3"
                android:background="@drawable/item_price"
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="20dp"
                android:fontFamily="@font/uni_sans"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/full_extra_button"
            android:tag="binding_4"
            android:background="@drawable/item_extra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp">
            <ImageView
                android:tag="binding_5"
                android:layout_width="90dp"
                android:layout_height="90dp"/>
            <TextView
                android:textSize="22sp"
                android:textColor="@color/black"
                android:tag="binding_6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="7dp"
                android:fontFamily="@font/uni_sans"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-15dp">
            <Space
                android:layout_width="140dp"
                android:layout_height="match_parent"/>
            <ImageButton
                android:id="@+id/subtract_extra"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/minus_extra"
                android:scaleType="fitXY"/>
            <Space
                android:layout_width="10dp"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="20sp"
                android:textColor="@color/black"
                android:layout_gravity="center"
                android:tag="binding_7"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:fontFamily="@font/uni_sans"
                android:textAlignment="center"/>
            <Space
                android:layout_width="10dp"
                android:layout_height="match_parent"/>
            <ImageButton
                android:id="@+id/add_extra"
                android:tag="binding_8"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/plus_extra"
                android:scaleType="fitXY"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textSize="40sp"
        android:textColor="@color/red"
        android:tag="binding_9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        android:rotation="-45"
        android:fontFamily="@font/uni_sans"
        android:textAlignment="center"/>
</RelativeLayout>
