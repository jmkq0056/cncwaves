<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="25dp"
        android:paddingVertical="50dp">
        <TextView
            android:textSize="40sp"
            android:textColor="@color/black"
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/uni_sans"
            android:textAlignment="center"/>
        <Space
            android:layout_width="match_parent"
            android:layout_height="50dp"/>
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/items"
            android:layout_width="match_parent"
            android:layout_height="1350dp"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/side_indicators_wrap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/side_previous"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="10dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/navigate_left"/>
            </RelativeLayout>
            <me.relex.circleindicator.CircleIndicator3
                android:id="@+id/side_indicators"
                android:layout_width="wrap_content"
                android:layout_height="70dp"
                app:ci_drawable="@drawable/page_indicator_new_active"
                app:ci_drawable_unselected="@drawable/page_indicator_new"
                app:ci_height="20dp"
                app:ci_margin="10dp"
                app:ci_width="20dp"/>
            <RelativeLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/side_next"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="10dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/navigate_right"/>
            </RelativeLayout>
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="50dp"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="30sp"
            android:textColor="@color/white"
            android:id="@+id/skip"
            android:background="@drawable/success_button"
            android:layout_width="460dp"
            android:layout_height="wrap_content"
            android:text="It&apos;s all. Thanks"
            android:fontFamily="@font/uni_sans"
            android:paddingVertical="20dp"/>
    </LinearLayout>
    <ImageView
        android:id="@+id/cart_icon"
        android:visibility="invisible"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/cart_icon"/>
</RelativeLayout>
