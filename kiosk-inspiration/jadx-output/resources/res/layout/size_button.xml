<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/size_button_0"
    android:padding="10dp"
    android:layout_width="400dp"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/button"
        android:background="@drawable/item_button"
        android:padding="20dp"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="430dp">
        <ImageView
            android:tag="binding_1"
            android:layout_width="@dimen/size_image_height"
            android:layout_height="@dimen/size_image_height"/>
        <TextView
            android:textSize="37sp"
            android:textColor="@color/black"
            android:id="@+id/size_name"
            android:tag="binding_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/uni_sans"
            android:textAlignment="center"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@color/black"
            android:id="@+id/item_name"
            android:tag="binding_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/uni_sans"
            android:textAlignment="center"/>
        <TextView
            android:textSize="28sp"
            android:textColor="@color/black"
            android:id="@+id/size_price"
            android:tag="binding_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/uni_sans"/>
    </LinearLayout>
    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/hand"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
