<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cnc_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="2" />

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="320dp"
            android:layout_height="160dp"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Taste is a passion"
            android:textSize="24sp"
            android:textColor="@color/cnc_red"
            android:textStyle="italic"
            android:fontFamily="serif"
            android:layout_marginTop="8dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView
            android:id="@+id/tapText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BESTIL HERFRA\nOG SPAR TID"
            android:textSize="34sp"
            android:textColor="@color/cnc_text"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="3" />

        <TextView
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/cnc_red"
            android:text="KLIK HER FOR AT BESTILLE"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.08" />
    </LinearLayout>
</FrameLayout>
