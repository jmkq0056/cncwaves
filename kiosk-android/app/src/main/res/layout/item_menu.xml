<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_rounded"
        android:elevation="3dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Image container with rounded top -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:clipChildren="true">

            <ImageView
                android:id="@+id/itemImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:background="@color/cnc_bg_warm"
                android:padding="8dp" />
        </FrameLayout>

        <!-- Name + Price -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/itemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/cnc_text"
                android:maxLines="2"
                android:ellipsize="end"
                android:gravity="center"
                android:lineSpacingExtra="-1dp" />

            <TextView
                android:id="@+id/itemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/price_badge"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

    <!-- Sold out overlay -->
    <FrameLayout
        android:id="@+id/soldOutOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/sold_out_overlay"
        android:visibility="gone">

        <TextView
            android:id="@+id/soldOutLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="UDSOLGT"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:rotation="-15"
            android:background="@color/cnc_sold_out"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp" />
    </FrameLayout>
</FrameLayout>
