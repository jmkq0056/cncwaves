        <item name="colorPrimary">@color/cnc_red</item>
        <item name="colorPrimaryDark">@color/cnc_red_dark</item>
        <item name="colorAccent">@color/cnc_gold</item>
        <item name="android:windowBackground">@color/cnc_bg</item>
