<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CNC SIGNAGE"
            android:textColor="#FF6600"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Screen Number"
            android:textColor="#AAAAAA"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- Row 1: Screens 1-5 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn1" android:layout_width="56dp" android:layout_height="56dp" android:text="1" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
            <Button android:id="@+id/btn2" android:layout_width="56dp" android:layout_height="56dp" android:text="2" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
            <Button android:id="@+id/btn3" android:layout_width="56dp" android:layout_height="56dp" android:text="3" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
            <Button android:id="@+id/btn4" android:layout_width="56dp" android:layout_height="56dp" android:text="4" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
            <Button android:id="@+id/btn5" android:layout_width="56dp" android:layout_height="56dp" android:text="5" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
        </LinearLayout>

        <!-- Row 2: Screens 6-10 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn6" android:layout_width="56dp" android:layout_height="56dp" android:text="6" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
            <Button android:id="@+id/btn7" android:layout_width="56dp" android:layout_height="56dp" android:text="7" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
            <Button android:id="@+id/btn8" android:layout_width="56dp" android:layout_height="56dp" android:text="8" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
            <Button android:id="@+id/btn9" android:layout_width="56dp" android:layout_height="56dp" android:text="9" android:textSize="20sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
            <Button android:id="@+id/btn10" android:layout_width="56dp" android:layout_height="56dp" android:text="10" android:textSize="18sp" android:textColor="#FFFFFF" android:background="#333333" android:layout_margin="4dp" android:focusable="true" />
        </LinearLayout>

        <!-- Selected screen display -->
        <TextView
            android:id="@+id/selectedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No screen selected"
            android:textColor="#666666"
            android:textSize="18sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- START button -->
        <Button
            android:id="@+id/startButton"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:background="#FF6600"
            android:text="START"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:focusable="true"
            android:padding="16dp"
            android:layout_marginBottom="32dp" />

        <!-- Collapsible server URL section -->
        <Button
            android:id="@+id/changeServerButton"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            android:text="Change Server URL"
            android:textColor="#666666"
            android:textSize="12sp"
            android:focusable="true"
            android:padding="10dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/serverUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#222222"
            android:gravity="center"
            android:inputType="textUri"
            android:padding="14dp"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- Settings buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/wifiButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="#222222"
                android:text="WiFi"
                android:textColor="#888888"
                android:textSize="12sp"
                android:focusable="true"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/ethernetButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="#222222"
                android:text="Ethernet"
                android:textColor="#888888"
                android:textSize="12sp"
                android:focusable="true"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/systemSettingsButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="#222222"
                android:text="Settings"
                android:textColor="#888888"
                android:textSize="12sp"
                android:focusable="true"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_margin="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
